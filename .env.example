# Optional shared override for both the Next.js app and CSV importer.
# When omitted, both use the local Docker PostgreSQL defaults.
DATABASE_URL=postgresql://linea:linea_password@localhost:5432/linea_db

# Safest default: no model server or paid API is required.
MODEL_PROVIDER=deterministic
MODEL_BASE_URL=
MODEL_API_KEY=
MODEL_NAME=
MODEL_TIMEOUT_MS=15000

# Local open-source model via Ollama (recommended model path).
# Copy these values to .env.local and replace the deterministic settings above.
# MODEL_PROVIDER=ollama
# MODEL_BASE_URL=http://localhost:11434
# MODEL_API_KEY=
# MODEL_NAME=llama3.2
# MODEL_TIMEOUT_MS=15000

# Optional hosted/OpenAI-compatible adapter. This is not required to run Linea.
# Use the base URL, API key, and model name supplied by your chosen provider.
# MODEL_PROVIDER=openai_compatible
# MODEL_BASE_URL=https://your-provider.example/v1
# MODEL_API_KEY=replace-with-your-provider-key
# MODEL_NAME=your-model-name
# MODEL_TIMEOUT_MS=15000

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=linea_knowledge_base
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_URL=http://localhost:5678/webhook/linea-demo
